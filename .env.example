# Copy to .env for local runs. In Render, set these as Environment Variables.
# NEVER commit real values (App Secret especially).

MEEVO_APP_ID=your-app-id-uuid
MEEVO_APP_SECRET=your-app-secret-uuid
MEEVO_AUTH_URL=https://marketplace.meevo.com/oauth2/token
# Host only — /publicapi/vN is added by the code (it also strips it if you paste the full base).
MEEVO_BASE_URL=https://na2pub.meevo.com
MEEVO_TENANT_ID=502388
MEEVO_LOCATION_ID=503369
PORT=10000
